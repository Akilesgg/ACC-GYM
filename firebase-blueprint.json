{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile data including fitness goals and progress.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin", "trainer"] },
        "selectedSports": { "type": "array" },
        "weight": { "type": "number" },
        "height": { "type": "number" },
        "age": { "type": "number" },
        "gender": { "type": "string" },
        "bodyFat": { "type": "number" },
        "nutritionGoal": { "type": "string" },
        "timeframe": { "type": "string" },
        "allergies": { "type": "string" },
        "nutritionPlan": { "type": "object" },
        "weightHistory": { "type": "array" },
        "photos": { "type": "array" },
        "progress": { "type": "object" },
        "streak": { "type": "number" },
        "deviceData": { "type": "object" }
      },
      "required": ["uid", "email", "role"]
    },
    "Sport": {
      "title": "Sport",
      "description": "Sport definition.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["id", "name", "icon", "category"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/sports/{sportId}": {
      "schema": "Sport",
      "description": "Available sports collection."
    }
  }
}
